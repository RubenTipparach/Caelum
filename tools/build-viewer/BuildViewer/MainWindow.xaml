<Window x:Class="BuildViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Build Script Viewer" Width="1000" Height="700"
        Background="#1a1a2e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: file list + script info -->
        <Border Grid.Column="0" Background="#16213e" Margin="4" CornerRadius="4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="8">
                    <TextBlock Text="Build Scripts" FontSize="16" FontWeight="Bold"
                               Foreground="#e0e0ff" Margin="0,0,0,8"/>
                    <Button x:Name="BtnOpen" Content="Open Folder..." Click="OnOpenFolder"
                            Background="#2a3a5c" Foreground="White" Padding="8,4"
                            BorderBrush="#4a5a8c" Margin="0,0,0,4"/>
                    <Button x:Name="BtnToggleShape" Content="Shape: Hex" Click="OnToggleShape"
                            Background="#2a3a5c" Foreground="White" Padding="8,4"
                            BorderBrush="#4a5a8c" Margin="0,0,0,8"/>
                </StackPanel>

                <ListBox x:Name="ScriptList" SelectionChanged="OnScriptSelected"
                         Background="Transparent" Foreground="#c0c0e0"
                         BorderThickness="0" Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#c0c0e0" Padding="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right panel: 3D preview + info -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- 3D Viewport -->
            <Border Grid.Row="0" Background="#0f0f1a" Margin="4" CornerRadius="4">
                <Viewport3D x:Name="Viewport" ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="Camera"
                            Position="5,8,12" LookDirection="-5,-8,-12"
                            UpDirection="0,1,0" FieldOfView="60"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <DirectionalLight Color="White" Direction="-1,-1,-1"/>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <AmbientLight Color="#404040"/>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                    <ModelVisual3D x:Name="BlocksModel"/>
                </Viewport3D>
            </Border>

            <!-- Script info panel -->
            <Border Grid.Row="1" Background="#16213e" Margin="4" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                    <StackPanel>
                        <TextBlock x:Name="TxtName" FontSize="16" FontWeight="Bold"
                                   Foreground="#e0e0ff" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDesc" Foreground="#a0a0c0"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtStats" Foreground="#80809a" FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
